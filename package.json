{
  "name": "ts-data-forge-monorepo",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "typescript",
    "utility",
    "types",
    "static-typing",
    "functional-programming",
    "type-guard"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noshiro-pf/ts-data-forge.git"
  },
  "license": "Apache-2.0",
  "author": "noshiro-pf <noshiro.pf@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/**"
  ],
  "scripts": {
    "build": "pnpm run ws:build",
    "build:min": "pnpm run ws:build",
    "check:ext": "pnpm run ws:check:ext",
    "check:root": "pnpm run '/check:root:.*/'",
    "check:root:lint": "pnpm run z:eslint ./{scripts,configs}/**/*.mts --fix",
    "check:root:type": "node ./node_modules/typescript-native/bin/tsc -p ./tsconfig.json --noEmit",
    "check-all": "tsx ./scripts/cmd/check-all.mts",
    "ci:publish": "pnpm run ws:build && pnpm changeset publish",
    "ci:version-packages": "pnpm changeset version && pnpm install --no-frozen-lockfile",
    "clean:node_modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "codemod": "run-s codemod:uncommitted:as-const fmt codemod:uncommitted:readonly fmt",
    "codemod:diff": "run-s codemod:diff:as-const fmt codemod:diff:readonly fmt",
    "codemod:diff:as-const": "append-as-const --diff-from origin/main 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "codemod:diff:readonly": "convert-to-readonly --diff-from origin/main 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "codemod:full": "run-s codemod:full:as-const fmt codemod:full:readonly fmt",
    "codemod:full:as-const": "append-as-const 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "codemod:full:readonly": "convert-to-readonly 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "codemod:uncommitted:as-const": "append-as-const --uncommitted 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "codemod:uncommitted:readonly": "convert-to-readonly --uncommitted 'packages/*/{src,scripts,samples,test}/**/*.{mts,tsx}'",
    "cspell": "cspell \"**\" --gitignore --gitignore-root ./ --no-progress",
    "doc": "pnpm run ws:doc",
    "fmt": "format-uncommitted",
    "fmt:diff": "format-diff-from origin/main",
    "fmt:full": "prettier --ignore-unknown --no-error-on-unmatched-pattern --write .",
    "gh:apply-all": "gh-apply-all",
    "gh:apply-repository-settings": "gh-apply-repository-settings",
    "gh:apply-rulesets": "gh-apply-rulesets",
    "gh:apply-variables": "gh-apply-variables",
    "gh:backup-all": "gh-backup-all",
    "gh:backup-repository-settings": "gh-backup-repository-settings",
    "gh:backup-rulesets": "gh-backup-rulesets",
    "lint:fix": "pnpm run ws:lint:fix",
    "md": "markdownlint-cli2",
    "test": "pnpm run ws:test",
    "test:browser": "pnpm run ws:test:browser",
    "test:cov": "pnpm run ws:test:cov",
    "update-dependencies": "pnpm update --latest -r '!eslint' '!typescript'",
    "ws:build": "tsx ./scripts/cmd/ws-build-stages.mts",
    "ws:check:ext": "pnpm run --recursive --if-present check:ext",
    "ws:doc": "pnpm run --recursive --if-present doc",
    "ws:doc:embed": "pnpm run --recursive --if-present doc:embed",
    "ws:doc:embed:jsdoc": "pnpm run --recursive --if-present doc:embed:jsdoc",
    "ws:gi": "pnpm run --recursive --if-present gi",
    "ws:lint": "pnpm run --recursive --if-present lint",
    "ws:lint:fix": "pnpm run --recursive --if-present lint:fix",
    "ws:test": "pnpm run --recursive --if-present test",
    "ws:test:browser": "pnpm run --recursive --if-present test:browser",
    "ws:test:cov": "pnpm run --recursive --if-present test:cov",
    "ws:tsc": "pnpm run --recursive --if-present tsc",
    "ws:type-check": "pnpm run --recursive --if-present type-check",
    "z:eslint": "NODE_OPTIONS='--max-old-space-size=6144' TIMING=1 eslint"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-strip": "3.0.4",
    "@types/node": "26.1.0",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.9",
    "cspell": "10.0.1",
    "dedent": "1.7.2",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-config-typed": "5.3.0",
    "github-settings-as-code": "1.2.9",
    "jiti": "2.7.0",
    "markdownlint": "0.41.0",
    "markdownlint-cli2": "0.23.0",
    "npm-run-all2": "9.0.2",
    "playwright": "1.61.1",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "rollup": "4.62.2",
    "rollup-plugin-esbuild": "6.2.1",
    "ts-codemod-lib": "2.2.1",
    "ts-repo-utils": "10.1.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-native": "npm:typescript@7.0.1-rc",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "26.3.1"
  }
}
